# Copy this file to .env and replace placeholder values as needed

# ------------------------------------------------------------------
# Django core settings
# ------------------------------------------------------------------
SECRET_KEY=replace_me_with_random_64_chars
DEBUG=True  # Set to True only in local development

# ------------------------------------------------------------------
# PostgreSQL database connection
# ------------------------------------------------------------------
POSTGRES_DB_NAME=jteam_db
POSTGRES_DB_USER=jteam_user
POSTGRES_DB_PASSWORD=supersecret
POSTGRES_DB_HOST=database
POSTGRES_DB_PORT=5432

# Django expects the variables below (do not change unless necessary)
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=${POSTGRES_DB_NAME}
POSTGRES_USER=${POSTGRES_DB_USER}
POSTGRES_PASSWORD=${POSTGRES_DB_PASSWORD}
DB_HOST=${POSTGRES_DB_HOST}
DB_PORT=${POSTGRES_DB_PORT}

# ------------------------------------------------------------------
# PGAdmin (optional)
# ------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_password

# ------------------------------------------------------------------
# Stripe payments
# ------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_API_VERSION=2022-08-01
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ------------------------------------------------------------------
# Email (Yandex SMTP) – adjust for your provider if different
# ------------------------------------------------------------------
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=email_password
ADMINS=[["Admin","you@example.com"]]

# ------------------------------------------------------------------
# Social authentication
# ------------------------------------------------------------------
SOCIAL_AUTH_FACEBOOK_KEY=facebook_app_id
SOCIAL_AUTH_FACEBOOK_SECRET=facebook_app_secret
SOCIAL_AUTH_FACEBOOK_SCOPE=email
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=google_client_id
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=google_client_secret

# ------------------------------------------------------------------
# Marketplace (venue rental, cart, payments)
# ------------------------------------------------------------------
MARKETPLACE_ENABLED=false

# ------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1]

# ------------------------------------------------------------------
# Yandex Maps API
# ------------------------------------------------------------------
# Локальная разработка: HTTP Referer во всех ключах = localhost (без порта).
# Открывайте сайт через http://localhost:8000/, не 127.0.0.1.
#
# TODO перед продакшеном: добавить реальный домен в HTTP Referer
# во ВСЕХ трёх ключах в кабинете Yandex (developer.tech.yandex.ru):
#   1. JavaScript API          → YANDEX_MAPS_API_KEY
#   2. API Геосаджеста         → YANDEX_MAPS_SUGGEST_API_KEY
#   3. API Геокодера           → YANDEX_GEOCODER_API_KEY
# Пример: jteam.ru  (поддомены добавляются автоматически)
# Также обновите YANDEX_MAPS_REFERER=https://jteam.ru/
# Поле IP-адресов для серверных ключей оставьте пустым или укажите IP сервера.
# ------------------------------------------------------------------
YANDEX_MAPS_API_KEY=yandex_maps_api_key
YANDEX_MAPS_API_KEY_STATIC=yandex_maps_static_key
# Ключ Geosuggest API для подсказок адресов (если не задан, используется YANDEX_MAPS_API_KEY)
YANDEX_MAPS_SUGGEST_API_KEY=yandex_maps_suggest_api_key
# Referer для серверных запросов к HTTP Geocoder (должен совпадать с ограничениями ключа)
YANDEX_MAPS_REFERER=http://localhost:8000/
# Отдельный ключ HTTP Geocoder, если отличается от JavaScript API (необязательно)
YANDEX_GEOCODER_API_KEY=yandex_geocoder_api_key

DJANGO_ENV=local  # Change to 'production' in prod
